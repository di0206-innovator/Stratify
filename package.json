{
  "name": "stratify",
  "version": "1.0.0",
  "description": "Stratify — The Operating System for the Startup Economy",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:cluster": "node cluster.js",
    "server": "node server.js",
    "dev:frontend": "vite",
    "dev:server": "node server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "migrate": "node lib/db/migrate.js",
    "build": "vite build",
    "test": "node --test",
    "test-cli": "node bin/cli.js",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.43.4",
    "canvas-confetti": "^1.9.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.395.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11"
  }
}
