# ════════════════════════════════════════════════════════════════════
#  NeuralBI — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════

# ── Core AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
TAVILY_API_KEY=your_tavily_api_key_here

# ── Clerk Auth ──────────────────────────────────────────────────────
# Required for user authentication.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Supabase (scalable backend database) ─────────────────────────────
# Required for Supabase client connection.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── PostgreSQL (scalable backend) ────────────────────────────────────
# When set, the app uses PostgreSQL instead of JSON file stores.
# Leave blank to use file-based stores (local dev without Docker).
#
# Option A: Connection URL (preferred, Cloud SQL / Railway / Supabase)
DATABASE_URL=
#
# Option B: Individual connection params (used if DATABASE_URL is blank)
PGHOST=localhost
PGPORT=5432
PGDATABASE=neuralbi
PGUSER=neuralbi
PGPASSWORD=neuralbi_local
PGSSL=false
#
# Connection pool size per Node.js worker (e.g. 20 workers × 20 = 400 total)
PG_POOL_MAX=20
PG_POOL_MIN=2
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000

# ── Redis (distributed sessions, rate limiting, cache) ───────────────
# When set, the app uses Redis for sessions and rate limiting.
# Leave blank to use in-memory sessions (local dev without Docker).
#
# Option A: URL (preferred, Cloud Memorystore / Upstash / Redis Cloud)
REDIS_URL=
#
# Option B: Individual params
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ── Cluster ──────────────────────────────────────────────────────────
# Number of Node.js worker processes to spawn (default: CPU count).
# Set to 1 in Kubernetes/Docker (let the orchestrator handle replicas).
WORKERS=

# ── HTTP Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────
API_AUTH_TOKEN=
SESSION_TTL_MS=604800000              # 7 days
EMAIL_VERIFICATION_TOKEN_TTL_MS=86400000  # 24 hours
PASSWORD_RESET_TOKEN_TTL_MS=1800000   # 30 minutes
LOGIN_RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
LOGIN_RATE_LIMIT_MAX=5                # 5 login attempts per window
REQUIRE_AUTH_FOR_ANALYZE=false

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000            # 1 minute
RATE_LIMIT_MAX=20                     # 20 API requests per minute

# ── Storage Paths (file-store fallback) ──────────────────────────────
AUTH_STORE_PATH=
REPORT_STORE_PATH=
SIGNAL_STORE_PATH=
MAX_STORED_REPORTS=500

# ── HTTP ─────────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com
JSON_BODY_LIMIT=128kb
REQUEST_TIMEOUT_MS=60000
